# ---------------------------------------------------------------------------
# Polymarket US API credentials
# ---------------------------------------------------------------------------
# Create an API key in your Polymarket US account, then paste the values here.
# `POLYMARKET_KEY_ID`     -> the API key ID (a UUID)
# `POLYMARKET_SECRET_KEY` -> the base64-encoded Ed25519 secret key
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored — never commit real credentials.
POLYMARKET_KEY_ID=your-api-key-id-uuid
POLYMARKET_SECRET_KEY=your-base64-ed25519-secret-key

# ---------------------------------------------------------------------------
# Optional: override Polymarket API base URLs (defaults shown)
# ---------------------------------------------------------------------------
# POLYMARKET_GATEWAY_BASE_URL=https://gateway.polymarket.us
# POLYMARKET_API_BASE_URL=https://api.polymarket.us

# ---------------------------------------------------------------------------
# Backend server configuration
# ---------------------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Comma-separated list of origins allowed to call the backend (the Next.js app).
CORS_ALLOW_ORIGINS=http://localhost:3000
